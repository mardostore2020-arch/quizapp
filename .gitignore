# Créer le fichier .gitignore
cat > .gitignore << EOF
# Compiled files
*.class
target/
*.jar
*.war
*.ear

# IDE files - NetBeans
nbproject/
nb-configuration.xml
.settings/
.project
.classpath

# IDE files - IntelliJ/IDEA
.idea/
*.iml

# IDE files - Eclipse
.settings/
.project
.classpath

# Maven
.mvn/
mvnw
mvnw.cmd

# Logs
*.log

# OS files
.DS_Store
Thumbs.db
EOF